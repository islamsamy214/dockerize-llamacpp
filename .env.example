# Copy to .env and edit. Both compose files read from this single source.
#   cp .env.example .env

# ─── Image ───────────────────────────────────────────────────────────────────
# The `full-intel` tag is MUTABLE — it moves under you. Pin by digest in anything
# you care about. Resolve the current digest with:
#   docker buildx imagetools inspect ghcr.io/ggml-org/llama.cpp:full-intel
# then set: LLAMA_IMAGE=ghcr.io/ggml-org/llama.cpp:full-intel@sha256:<digest>
LLAMA_IMAGE=ghcr.io/ggml-org/llama.cpp:full-intel

# ─── Host paths (BIND MOUNTS, not named volumes) ─────────────────────────────
# Relative paths resolve next to the compose file. Use absolute paths you own
# (e.g. /home/islacks/models) if you want them outside the project dir.
MODELS_DIR=./data/models
HF_CACHE_DIR=./data/hf-cache

# ─── GPU offload ─────────────────────────────────────────────────────────────
# 99 = offload all layers to the Intel Arc iGPU; 0 = CPU only.
NGL=99

# ─── Server (uses a local GGUF that already lives under MODELS_DIR) ───────────
SERVER_MODEL_FILE=gemma-4-E4B-it-Q4_K_M.gguf
SERVER_CTX=8192
PARALLEL=1
HOST_PORT=8080

# ─── Playground (pulls straight from HF, caches into HF_CACHE_DIR) ───────────
DEV_MODEL_HF=ggml-org/gemma-4-E4B-it-GGUF:Q4_K_M
DEV_CTX=4096

# ─── Sampling (Gemma 4 recommended defaults) ─────────────────────────────────
TEMP=1.0
TOP_P=0.95
TOP_K=64

# ─── Resource ceilings (server) ──────────────────────────────────────────────
# Keep MEM_LIMIT above model size + KV cache + overhead. On an iGPU the
# offloaded weights live in SYSTEM RAM and count against this cgroup, so don't
# starve it. Gemma 4 E4B Q4_K_M is ~5.3 GB.
MEM_LIMIT=12G
MEM_RESERVATION=6G
CPU_LIMIT=8
